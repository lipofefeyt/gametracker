# Gmail sender address
SENDER_EMAIL=you@gmail.com

# Gmail App Password (not your login password)
# Generate one at: https://myaccount.google.com/apppasswords
APP_PASSWORD=xxxx xxxx xxxx xxxx

# Address to receive deal alert emails
RECEIVER_EMAIL=you@gmail.com

# Steam store country code (ISO 3166-1 alpha-2)
# Controls currency — e.g. us=USD, gb=GBP, fr=EUR, de=EUR
STEAM_COUNTRY_CODE=us
